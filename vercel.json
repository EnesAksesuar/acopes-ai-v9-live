{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "public" }
    },
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": { "maxDuration": 30 }
    }
  ],
  "routes": [
    { "src": "/",              "dest": "/index.html" },
    { "src": "/pricing",       "dest": "/pricing.html" },
    { "src": "/terms",         "dest": "/terms.html" },
    { "src": "/privacy",       "dest": "/privacy.html" },
    { "src": "/refund-policy", "dest": "/refund-policy.html" },
    { "handle": "filesystem" },
    { "src": "/(.*)",          "dest": "server.js" }
  ]
}
