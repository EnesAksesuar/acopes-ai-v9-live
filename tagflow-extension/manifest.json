{
  "manifest_version": 3,
  "name": "ACOPES AI · TagFlow",
  "short_name": "TagFlow",
  "description": "Etsy ürün kartlarında hover ile tag analizi. Rakabet skoru, en çok kullanılan taglar, düşük rekabetli fırsatlar.",
  "version": "2.0.0",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    },
    "default_title": "ACOPES AI · TagFlow"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.etsy.com/*"],
      "js":  ["content.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://www.etsy.com/*",
    "https://acopes-ai-production.up.railway.app/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
