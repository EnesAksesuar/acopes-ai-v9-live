# ── TagFlow API – environment variables ───────────────────────────────────────
# Copy this file to .env and fill in real values before running.

# Server port (local dev only; Vercel ignores this)
PORT=4200

# Anthropic key – server-side only, never exposed to the browser
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# JWT signing secret – generate with: openssl rand -hex 32
TAGFLOW_JWT_SECRET=replace-with-64-char-random-string

# Directory where tagflow.db will be created (defaults to project root)
# ACOPES_DATA_DIR=/data
