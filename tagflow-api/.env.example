# ── TagFlow API – environment variables ───────────────────────────────────────
# Copy this file to .env and fill in real values before running.

# Server port (Railway sets this automatically; local dev defaults to 4200)
PORT=4200

# Anthropic key – server-side only, never exposed to the browser
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# JWT signing secret – generate with: openssl rand -hex 32
TAGFLOW_JWT_SECRET=replace-with-64-char-random-string

# ── Railway: persistent volume must be mounted at /data ──────────────────────
# In Railway dashboard: Variables → Add → ACOPES_DATA_DIR = /data
# Then: Volumes → Add Volume → Mount Path: /data
# tagflow.db will be created at /data/acopes-ai/tagflow.db
ACOPES_DATA_DIR=/data
